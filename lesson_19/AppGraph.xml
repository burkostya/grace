    <annotation>Прототип ERP-системы для управления накладными с использованием Dash и AG Grid.</annotation>
    <BusinessScenarios>
      <Scenario NAME="GenerateData">Пользователь генерирует 5 случайных накладных для демонстрации.</Scenario>
      <Scenario NAME="EditInvoice">Пользователь выбирает накладную и редактирует количество товаров с пересчетом суммы.</Scenario>
      <Scenario NAME="Analytics">Пользователь просматривает график распределения сумм по накладным.</Scenario>
    </BusinessScenarios>
  </Lesson_19_ERP_Prototype_Info>

